{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the dating app",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "age": { "type": "integer", "description": "User's age" },
        "gender": { "type": "string", "enum": ["male", "female", "non-binary", "other"] },
        "interestedIn": { "type": "array", "items": { "type": "string" }, "description": "Genders the user is interested in" },
        "bio": { "type": "string", "description": "User's biography" },
        "photoURL": { "type": "string", "description": "Primary profile picture URL" },
        "photos": { "type": "array", "items": { "type": "string" }, "description": "Additional profile pictures" },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "List of user interests" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" }, "city": { "type": "string" } } },
        "isVerified": { "type": "boolean", "description": "Whether the user is identity verified" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "isPremium": { "type": "boolean", "description": "Whether the user has a premium subscription" }
      },
      "required": ["uid", "displayName", "age", "gender", "photoURL"]
    },
    "Match": {
      "title": "Match",
      "description": "A match between two users",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" }, "description": "Array of two user UIDs" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string", "description": "Snippet of the last message" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "imageURL": { "type": "string" },
        "voiceURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      }
    },
    "Report": {
      "title": "Report",
      "description": "A safety report against a user",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reportedId": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] }
      }
    },
    "Block": {
      "title": "Block",
      "description": "A block between users",
      "type": "object",
      "properties": {
        "blockerId": { "type": "string" },
        "blockedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/matches/{matchId}": { "schema": "Match", "description": "Matches between users" },
    "/matches/{matchId}/messages/{messageId}": { "schema": "Message", "description": "Messages in a match" },
    "/reports/{reportId}": { "schema": "Report", "description": "User reports" },
    "/blocks/{blockId}": { "schema": "Block", "description": "User blocks" }
  }
}
