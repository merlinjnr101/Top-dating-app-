rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - age: number (required)
    //   - gender: string (required)
    //   - photoURL: string (required)
    //   - bio: string
    //   - photos: list
    //   - interests: list
    //   - location: map
    //   - isVerified: bool
    //   - createdAt: timestamp
    //   - lastActive: timestamp
    //   - isPremium: bool
    //   - role: string
    //
    // Collection: matches
    // Document ID: {matchId}
    // Fields:
    //   - users: list (required, size 2)
    //   - createdAt: timestamp
    //   - lastMessage: string
    //   - lastMessageAt: timestamp
    //
    // Collection: matches/{matchId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - text: string
    //   - imageURL: string
    //   - voiceURL: string
    //   - createdAt: timestamp
    //   - read: bool
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - reporterId: string (required)
    //   - reportedId: string (required)
    //   - reason: string (required)
    //   - details: string
    //   - createdAt: timestamp
    //   - status: string
    //
    // Collection: blocks
    // Document ID: {blockId}
    // Fields:
    //   - blockerId: string (required)
    //   - blockedId: string (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions (Simplified for Mock Auth)
    // ===============================================================
    function isMockAuthenticated() {
      // Since we removed Firebase Auth, request.auth will be null.
      // For the demo to work, we allow all access.
      // WARNING: This is insecure and only for demo purposes without Firebase Auth.
      return true;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'age', 'gender', 'photoURL']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.age is number && data.age >= 18 && data.age < 120 &&
             data.gender in ['male', 'female', 'non-binary', 'other'] &&
             data.photoURL is string && data.photoURL.size() < 2000;
    }

    function isValidMatch(data) {
      return data.users is list && data.users.size() == 2;
    }

    function isValidMessage(data) {
      return data.senderId is string &&
             (data.text is string || data.imageURL is string || data.voiceURL is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isMockAuthenticated();
      allow create: if isMockAuthenticated() && isValidUser(request.resource.data);
      allow update: if isMockAuthenticated() && isValidUser(request.resource.data);
    }

    match /matches/{matchId} {
      allow read: if isMockAuthenticated();
      allow create: if isMockAuthenticated();
      allow update: if isMockAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isMockAuthenticated();
        allow create: if isMockAuthenticated() && isValidMessage(request.resource.data);
      }
    }

    match /reports/{reportId} {
      allow read: if isMockAuthenticated();
      allow create: if isMockAuthenticated();
    }

    match /blocks/{blockId} {
      allow read: if isMockAuthenticated();
      allow create: if isMockAuthenticated();
      allow delete: if isMockAuthenticated();
    }
  }
}
